# Optionnel : copier en .env dans Docker/ ou : docker compose -f docker-compose.signaling.yml --env-file env.signaling.example up --build

SIGNALING_PUBLISH_PORT=5174

# Par défaut le compose met DISABLE_BDD=true (signalisation seule).
# Pour activer la persistance replay vers ServerBDD ailleurs, définir par ex. :
# DISABLE_BDD=false
# BDD_URL=http://host.docker.internal:5175
