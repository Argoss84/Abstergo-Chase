# Copier vers Docker/.env puis ajuster (docker compose charge automatiquement .env depuis le dossier courant)

MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=abstergo
MYSQL_USER=abstergo
MYSQL_PASSWORD=change-me-app

# Ports publiés vers la machine hôte
WEB_PUBLISH_PORT=8080
SIGNALING_PUBLISH_PORT=5174
SERVERBDD_PUBLISH_PORT=5175

# URLs injectées au build du frontend (vues depuis le navigateur de l’utilisateur, pas depuis un conteneur)
# Exemple machine locale avec les ports par défaut du compose :
VITE_API_URL=http://localhost:5175
VITE_SIGNALING_URL=http://localhost:5174

# Déploiement derrière un domaine (exemple) :
# VITE_API_URL=https://api.example.com
# VITE_SIGNALING_URL=https://ws.example.com
