# Pour docker-compose.monitor.yml (signaling déjà lancé ailleurs)

MONITOR_PUBLISH_PORT=8090

# URL vue depuis le conteneur monitor vers le signaling
#  - signaling en local sur la machine : host.docker.internal (Windows/Mac Docker Desktop)
#  - Linux souvent : ip de la passerelle docker ou --add-host
SIGNALING_URL=http://host.docker.internal:5174

SOCKET_IO_PATH=/socket.io
