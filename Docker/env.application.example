# Copier en .env à côté du compose ou : docker compose -f docker-compose.application.yml --env-file env.application.example up --build

# Port HTTP du conteneur (nginx) sur la machine hôte
APPLICATION_PUBLISH_PORT=8080

# URLs utilisées par le navigateur pour ServerBDD et la signalisation
VITE_API_URL=http://localhost:5175
VITE_SIGNALING_URL=http://localhost:5174

# Optionnel — TURN / WebRTC
# VITE_TURN_URL=turn:turn.example.com:3478?transport=tcp
# VITE_TURN_USERNAME=user
# VITE_TURN_CREDENTIAL=secret
